{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/preload/*.d.ts",
    "src/shared/**/*",
    "src/main/worker/platform/3In1bet/common/constants.ts",
    "src/main/worker/platform/3In1bet/common/types.ts",
    "src/main/worker/platform/P88/common/types.ts",
    "src/main/worker/platform/Viva88/common/types.ts",
    "src/main/worker/platform/Sbobet/common/types.ts"
  ],
  "compilerOptions": {
    "composite": true,
    "module": "ESNext",
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],
    "jsx": "react-jsx",
    "noUnusedLocals": false,
    "moduleResolution": "bundler",
    "rootDir": ".",
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@shared/*": ["./src/shared/*"],
      "@/*": ["./src/renderer/src/*"]
    }
  }
}